<!DOCTYPE html>
<html lang="en" class="scroll-smooth" id="htmlElement">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Caleb Howard | Academic Achievements & Educational Journey</title>
    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#6366F1', // Indigo 500
                        secondary: '#4F46E5', // Indigo 600
                        darkbg: '#0F172A', // Slate 900
                        darksurface: '#1E293B', // Slate 800
                        lighttext: '#F8FAFC', // Slate 50
                        mutedtext: '#94A3B8', // Slate 400,
                        codebg: '#1a202c' // Custom for code blocks
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: theme('colors.darkbg');
            color: theme('colors.lighttext');
        }
        .hero-bg {
            background: linear-gradient(to right bottom, theme('colors.darkbg'), theme('colors.darksurface'));
        }
        .section-separator {
            content: '';
            display: block;
            width: 80px;
            height: 4px;
            background-color: theme('colors.primary');
            margin: 0 auto 40px;
            border-radius: 2px;
        }
        @media (min-width: 768px) {
            .section-separator {
                margin: 0 0 40px; /* Align left on larger screens */
            }
        }
        /* Basic animation for hero elements */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-down { animation: fadeInDown 0.8s ease-out forwards; }
        .animate-fade-in-up { animation: fadeInUp 0.8s ease-out forwards; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-400 { animation-delay: 0.4s; }
        .delay-600 { animation-delay: 0.6s; }

        /* Light mode overrides */
        html.light body {
            background-color: #F1F5F9; /* slate-100 */
            color: #0F172A; /* slate-900 */
        }
        html.light .bg-darkbg { background-color: #F1F5F9; }
        html.light .bg-darksurface { background-color: #FFFFFF; }
        html.light .text-lighttext { color: #0F172A; }
        html.light .text-mutedtext { color: #64748B; }
        html.light .border-darksurface { border-color: #E2E8F0; }
        html.light .bg-primary\/20 { background-color: rgba(99, 102, 241, 0.1); }
        html.light .codebg { background-color: #E2E8F0; }
        html.light .hero-bg {
            background: linear-gradient(to right bottom, #E2E8F0, #FFFFFF);
        }
    </style>
</head>
<body class="min-h-screen bg-darkbg text-lighttext" id="edu-page">
    <!-- Navigation (Copied from achievements.html) -->
    <nav class="bg-darksurface p-4 shadow-lg fixed w-full z-10">
        <div class="container mx-auto flex justify-between items-center">
            <a href="index.html" class="text-2xl font-bold text-primary">Caleb Howard</a>
            <div class="flex items-center space-x-4">
                <!-- Desktop Nav -->
                <div class="space-x-4 hidden md:flex">
                    <a href="about.html" class="text-mutedtext hover:text-lighttext transition-colors">About</a>
                    <a href="achievements.html" class="text-mutedtext hover:text-lighttext transition-colors">Projects & Achievements</a>
                    <a href="skills.html" class="text-mutedtext hover:text-lighttext transition-colors">Skills</a>
                    <a href="contact.html" class="text-mutedtext hover:text-lighttext transition-colors">Contact</a>
                </div>
                <!-- Theme Toggle -->
                <button id="theme-toggle" class="p-2 rounded-full text-mutedtext hover:text-lighttext focus:outline-none focus:ring-2 focus:ring-primary transition-colors">
                    <svg id="dark-mode-svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                    <svg id="light-mode-svg" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h1M3 12H2m8.66-8.66l-.707-.707M16.34 16.34l.707-.707M16.34 7.66l.707-.707M7.66 16.34l-.707.707M12 7a5 5 0 100 10 5 5 0 000-10z"></path>
                    </svg>
                </button>
                <!-- Mobile Menu Button -->
                <button id="mobile-menu-button" class="md:hidden p-2 rounded-md text-mutedtext hover:text-lighttext focus:outline-none focus:ring-2 focus:ring-primary transition-colors">
                    <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu (Hidden by default) -->
        <div id="mobile-menu" class="hidden md:hidden absolute top-16 left-0 w-full bg-darksurface shadow-lg py-2">
            <div class="flex flex-col space-y-2 px-4">
                <a href="about.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    About
                </a>
                <a href="achievements.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M17 16l4-4m-4 4l-4-4m4 4V8"></path></svg>
                    Projects & Achievements
                </a>
                <a href="skills.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4M17 17h4M16 3h4M3 16h4M17 3v4M3 3h.01M12 8v4l3 3m-3-3l-3 3"></path></svg>
                    Skills
                </a>
                <a href="contact.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    Contact
                </a>
            </div>
        </div>
    </nav>

    <main class="pt-16 py-20 md:py-24 px-4 bg-darkbg">
        <div class="container mx-auto max-w-4xl">
            <h1 class="text-4xl md:text-5xl font-bold text-primary mb-6 text-center md:text-left animate-fade-in-down">Academic Achievements & Educational Journey</h1>
            <div class="section-separator mx-auto md:mx-0"></div>

            <div class="space-y-6 text-lg mb-12 animate-fade-in-up delay-200">
                <p class="text-lighttext">
                    I began my academic journey at Kathituni Boarding Primary School, where I demonstrated early academic excellence by scoring 395/500 in the Kenya Certificate of Primary Education (KCPE) examinations. This performance placed me among the top students nationally and earned me a full scholarship to one of Kenya’s most prestigious secondary institutions — Starehe Boys’ Centre & School.
                </p>

                <!-- KCPE Certificate Card -->
                <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200 animate-fade-in-up delay-300">
                    <h3 class="text-xl font-semibold text-primary mb-2">KCPE Certificate</h3>
                    <p class="text-mutedtext mb-4">Click to view the Kenya Certificate of Primary Education (KCPE) certificate.</p>
                    <div class="relative cursor-pointer overflow-hidden rounded-lg group view-image-btn" data-image="kcpe.jpeg" aria-label="View KCPE Certificate">
                        <img src="kcpe.jpeg" alt="KCPE Certificate Thumbnail" class="w-full h-48 object-cover object-center transform transition-transform duration-300 group-hover:scale-105 rounded-md">
                        <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M15 12c0 1.657-1.343 3-3 3s-3-1.343-3-3 1.343-3 3-3 3 1.343 3 3z"></path>
                                <path d="M12 4.5C7.458 4.5 3.753 7.007 2 12c1.753 4.993 5.458 7.5 10 7.5s8.247-2.507 10-7.5c-1.753-4.993-5.458-7.5-10-7.5zm0 13c-3.593 0-6.753-1.992-8.25-5 1.497-3.008 4.657-5 8.25-5s6.753 1.992 8.25 5c-1.497 3.008-4.657 5-8.25 5z"></path>
                            </svg>
                        </div>
                    </div>
                </div>

                <p class="text-lighttext">
                    Starehe Boys’ is widely recognized for nurturing disciplined, high-achieving, and socially responsible young leaders. During my four years there, I developed not only academically but also in leadership, independence, and resilience. I successfully completed the Kenya Certificate of Secondary Education (KCSE) with a strong overall grade of B+, maintaining a consistent record of performance in a highly competitive academic environment.
                </p>

                <!-- KCSE Certificate Card -->
                <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200 animate-fade-in-up delay-300">
                    <h3 class="text-xl font-semibold text-primary mb-2">KCSE Certificate</h3>
                    <p class="text-mutedtext mb-4">Click to view the Kenya Certificate of Secondary Education (KCSE) certificate.</p>
                    <div class="relative cursor-pointer overflow-hidden rounded-lg group view-image-btn" data-image="kcse.jpeg" aria-label="View KCSE Certificate">
                        <img src="kcse.jpeg" alt="KCSE Certificate Thumbnail" class="w-full h-48 object-cover object-center transform transition-transform duration-300 group-hover:scale-105 rounded-md">
                        <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M15 12c0 1.657-1.343 3-3 3s-3-1.343-3-3 1.343-3 3-3 3 1.343 3 3z"></path>
                                <path d="M12 4.5C7.458 4.5 3.753 7.007 2 12c1.753 4.993 5.458 7.5 10 7.5s8.247-2.507 10-7.5c-1.753-4.993-5.458-7.5-10-7.5zm0 13c-3.593 0-6.753-1.992-8.25-5 1.497-3.008 4.657-5 8.25-5s6.753 1.992 8.25 5c-1.497 3.008-4.657 5-8.25 5z"></path>
                            </svg>
                        </div>
                    </div>
                </div>

                <p class="text-lighttext">
                    Beyond academics, I am also a skilled and creative visual artist, which led to my admission to Kenyatta University to pursue a Bachelor of Fine Arts — a testament to both my analytical and creative strengths.
                </p>
                <p class="text-lighttext">
                    However, my vision extended beyond local opportunities. I sought global exposure and advanced learning environments that would allow me to grow at the highest level. As a result of my academic record and potential, I earned admission offers from multiple international institutions:
                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6">
                    <!-- Webster University Card -->
                    <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200">
                        <h3 class="text-xl font-semibold text-primary mb-2">Webster University</h3>
                        <p class="text-mutedtext mb-4">
                            USA - Computer Science (BS) with emphasis in Machine Learning. Called on July 15th, 2025. Awarded 50% scholarship.
                        </p>
                        <button type="button" class="view-pdf-btn inline-flex items-center text-primary hover:text-secondary group" data-pdf="webster.pdf" aria-label="View Webster University Admission PDF">
                            <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm11-10h-2V7h-2v3h-2v2h2v3h2v-3h2v-2z"></path>
                            </svg>
                            <span class="text-sm">View Admission PDF</span>
                        </button>
                    </div>

                    <!-- Oakland University Card -->
                    <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200">
                        <h3 class="text-xl font-semibold text-primary mb-2">Oakland University</h3>
                        <p class="text-mutedtext mb-4">
                            USA - Computer Science as major. Called on September 15th, 2025.
                        </p>
                        <button type="button" class="view-pdf-btn inline-flex items-center text-primary hover:text-secondary group" data-pdf="oak.pdf" aria-label="View Oakland University Admission PDF">
                            <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm11-10h-2V7h-2v3h-2v2h2v3h2v-3h2v-2z"></path>
                            </svg>
                            <span class="text-sm">View Admission PDF</span>
                        </button>
                    </div>

                    <!-- Park University Card -->
                    <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200">
                        <h3 class="text-xl font-semibold text-primary mb-2">Park University</h3>
                        <p class="text-mutedtext mb-4">
                            USA - Bachelors program of Information and Computer Science. Called on February 13th, 2025.
                        </p>
                        <button type="button" class="view-pdf-btn inline-flex items-center text-primary hover:text-secondary group" data-pdf="park.pdf" aria-label="View Park University Admission PDF">
                            <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm11-10h-2V7h-2v3h-2v2h2v3h2v-3h2v-2z"></path>
                            </svg>
                            <span class="text-sm">View Admission PDF</span>
                        </button>
                    </div>

                    <!-- Cyprus International University Card -->
                    <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200">
                        <h3 class="text-xl font-semibold text-primary mb-2">Cyprus International University</h3>
                        <p class="text-mutedtext mb-4">
                            Cyprus - Bachelor in Information Technology. Called on July 2nd, 2025. 50% guaranteed international scholarship.
                        </p>
                        <button type="button" class="view-pdf-btn inline-flex items-center text-primary hover:text-secondary group" data-pdf="ciu.pdf" aria-label="View Cyprus International University Admission PDF">
                            <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm11-10h-2V7h-2v3h-2v2h2v3h2v-3h2v-2z"></path>
                            </svg>
                            <span class="text-sm">View Admission PDF</span>
                        </button>
                    </div>

                    <!-- University of Derby Card -->
                    <div class="bg-darksurface rounded-lg shadow-md p-6 border border-darksurface dark:border-darksurface light:bg-white light:border-slate-200">
                        <h3 class="text-xl font-semibold text-primary mb-2">University of Derby</h3>
                        <p class="text-mutedtext mb-4">
                            United Kingdom - Foundation Pathways Programme. Called on September 29th, 2025.
                        </p>
                        <button type="button" class="view-pdf-btn inline-flex items-center text-primary hover:text-secondary group" data-pdf="derby.pdf" aria-label="View University of Derby Admission PDF">
                            <svg class="w-5 h-5 mr-1" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM6 20V4h7v5h5v11H6zm11-10h-2V7h-2v3h-2v2h2v3h2v-3h2v-2z"></path>
                            </svg>
                            <span class="text-sm">View Admission PDF</span>
                        </button>
                    </div>
                </div>
                
                <p class="text-lighttext mt-6">
                    Receiving admission from institutions across three different countries reflects both academic capability and global competitiveness. Although financial limitations delayed immediate enrollment, these offers stand as strong evidence of my ability to meet international academic standards.
                </p>

                <h2 class="text-3xl font-bold text-lighttext mt-10 mb-4 text-center md:text-left animate-fade-in-up delay-400">Why This Matters</h2>
                <div class="section-separator mx-auto md:mx-0 !w-40"></div>
                <ul class="list-disc list-inside text-mutedtext ml-4 space-y-2 animate-fade-in-up delay-600">
                    <li><span class="font-medium text-lighttext">Early academic excellence</span></li>
                    <li><span class="font-medium text-lighttext">Ability to compete at national and international levels</span></li>
                    <li><span class="font-medium text-lighttext">Discipline shaped by one of Africa’s most respected schools</span></li>
                    <li><span class="font-medium text-lighttext">A rare combination of technical, analytical, and artistic ability</span></li>
                    <li><span class="font-medium text-lighttext">Ambition to pursue global standards of education and innovation</span></li>
                </ul>
                <p class="text-lighttext mt-6">
                    I am not only a student with grades, but a learner driven by curiosity, creativity, and the determination to build solutions that matter.
                </p>
            </div>

            <div class="text-center mt-12">
                <a href="achievements.html#achievements-content" class="inline-block bg-primary hover:bg-secondary text-lighttext font-bold py-3 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-75">
                    &larr; Back to Projects & Achievements
                </a>
            </div>
        </div>
    </main>

    <footer class="bg-darksurface p-8 text-center text-mutedtext text-sm">
        <p>&copy; 2025 Caleb Howard. All rights reserved.</p>
    </footer>

    <!-- Image Lightbox Modal -->
    <div id="image-lightbox" class="fixed inset-0 bg-darkbg bg-opacity-90 flex items-center justify-center z-50 p-4 hidden">
        <div class="relative max-w-4xl max-h-full mx-auto">
            <button id="lightbox-close-btn" class="absolute -top-10 right-0 bg-red-600 hover:bg-red-700 text-white p-2 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 z-10">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <img id="lightbox-image" src="" alt="Expanded Certificate Image" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-2xl">
        </div>
    </div>

    <!-- PDF Lightbox Modal -->
    <div id="pdf-lightbox" class="fixed inset-0 bg-darkbg bg-opacity-90 flex items-center justify-center z-50 p-4 hidden">
        <div class="relative w-full max-w-5xl h-full max-h-[90vh] mx-auto bg-darksurface rounded-lg shadow-2xl overflow-hidden">
            <button id="pdf-lightbox-close-btn" class="absolute -top-10 right-0 bg-red-600 hover:bg-red-700 text-white p-2 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 z-10">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <iframe id="pdf-viewer" src="" frameborder="0" class="w-full h-full"></iframe>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
