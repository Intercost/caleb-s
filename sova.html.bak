<!DOCTYPE html>
<html lang="en" class="scroll-smooth" id="htmlElement">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Caleb Howard | Project Sova</title>
    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: '#6366F1', // Indigo 500
                        secondary: '#4F46E5', // Indigo 600
                        darkbg: '#0F172A', // Slate 900
                        darksurface: '#1E293B', // Slate 800
                        lighttext: '#F8FAFC', // Slate 50
                        mutedtext: '#94A3B8', // Slate 400,
                        codebg: '#1a202c' // Custom for code blocks
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: theme('colors.darkbg');
            color: theme('colors.lighttext');
        }
        .hero-bg {
            background: linear-gradient(to right bottom, theme('colors.darkbg'), theme('colors.darksurface'));
        }
        .section-separator {
            content: '';
            display: block;
            width: 80px;
            height: 4px;
            background-color: theme('colors.primary');
            margin: 0 auto 40px;
            border-radius: 2px;
        }
        @media (min-width: 768px) {
            .section-separator {
                margin: 0 0 40px; /* Align left on larger screens */
            }
        }
        /* Basic animation for hero elements */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in-down { animation: fadeInDown 0.8s ease-out forwards; }
        .animate-fade-in-up { animation: fadeInUp 0.8s ease-out forwards; }
        .delay-200 { animation-delay: 0.2s; }
        .delay-400 { animation-delay: 0.4s; }
        .delay-600 { animation-delay: 0.6s; }

        /* Light mode overrides */
        html.light body {
            background-color: #F1F5F9; /* slate-100 */
            color: #0F172A; /* slate-900 */
        }
        html.light .bg-darkbg { background-color: #F1F5F9; }
        html.light .bg-darksurface { background-color: #FFFFFF; }
        html.light .text-lighttext { color: #0F172A; }
        html.light .text-mutedtext { color: #64748B; }
        html.light .border-darksurface { border-color: #E2E8F0; }
        html.light .bg-primary\/20 { background-color: rgba(99, 102, 241, 0.1); }
        html.light .codebg { background-color: #E2E8F0; }
        html.light .hero-bg {
            background: linear-gradient(to right bottom, #E2E8F0, #FFFFFF);
        }

        /* Narration Modal Styles */
        .sound-wave-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2px; /* Gap between bars */
            height: 100%;
        }

        .sound-bar {
            width: 4px;
            height: 10px; /* Base height */
            background-color: #F8FAFC; /* Explicitly white for dark mode visibility */
            border-radius: 2px;
            animation: soundWave 1.2s ease-in-out infinite alternate;
            opacity: 0.7;
        }

        .sound-bar.paused {
            animation-play-state: paused;
        }

        /* Generate delays for each bar */
        .delay-wave-1 { animation-delay: 0.1s; }
        .delay-wave-2 { animation-delay: 0.2s; }
        .delay-wave-3 { animation-delay: 0.3s; }
        .delay-wave-4 { animation-delay: 0.4s; }
        .delay-wave-5 { animation-delay: 0.5s; }
        .delay-wave-6 { animation-delay: 0.6s; }
        .delay-wave-7 { animation-delay: 0.7s; }
        .delay-wave-8 { animation-delay: 0.8s; }
        .delay-wave-9 { animation-delay: 0.9s; }
        .delay-wave-10 { animation-delay: 1.0s; }
        .delay-wave-11 { animation-delay: 1.1s; }
        .delay-wave-12 { animation-delay: 1.2s; }
        .delay-wave-13 { animation-delay: 1.3s; }
        .delay-wave-14 { animation-delay: 1.4s; }
        .delay-wave-15 { animation-delay: 1.5s; }


        @keyframes soundWave {
            0% { height: 10px; } /* Start small */
            25% { height: 30px; } /* Rise */
            50% { height: 50px; } /* Peak */
            75% { height: 30px; } /* Fall */
            100% { height: 10px; } /* Return to small */
        }

        #narration-text-container {
            -ms-overflow-style: none; /* IE and Edge */
            scrollbar-width: none; /* Firefox */
            overflow-y: auto; /* Allow manual scrolling */
        }
        #narration-text-container::-webkit-scrollbar {
            display: none; /* Chrome, Safari, Opera */
        }
        #narration-content {
            /* Removed absolute positioning and transforms for manual scrolling */
            text-align: left; /* Default text alignment */
        }

        /* Light mode overrides for modal elements */
        html.light #narration-modal .bg-darksurface { background-color: #FFFFFF; }
        html.light #narration-modal .text-lighttext { color: #0F172A; }
        html.light #narration-modal .text-mutedtext { color: #64748B; }
        html.light #narration-modal .border-darksurface { border-color: #E2E8F0; }
        html.light #narration-modal .sound-wave-container .sound-bar { background-color: #0F172A; } /* Dark bars in light mode */

        /* Custom scrollbar for better appearance (optional, if default is ugly and not hidden) */
        .custom-scrollbar::-webkit-scrollbar {
            width: 8px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: theme('colors.darksurface');
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: theme('colors.primary');
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: theme('colors.secondary');
        }
        html.light .custom-scrollbar::-webkit-scrollbar-track {
            background: #E2E8F0;
        }
        html.light .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #6366F1;
        }
        html.light .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #4F46E5;
        }
    </style>
</head>
<body class="min-h-screen">
    <!-- Navigation -->
    <nav class="bg-darksurface p-4 shadow-lg fixed w-full z-10">
        <div class="container mx-auto flex justify-between items-center">
            <a href="index.html" class="text-2xl font-bold text-primary">Caleb Howard</a>
            <div class="flex items-center space-x-4">
                <!-- Desktop Nav -->
                <div class="space-x-4 hidden md:flex">
                    <a href="about.html" class="text-mutedtext hover:text-lighttext transition-colors">About</a>
                    <a href="achievements.html" class="text-mutedtext hover:text-lighttext transition-colors">Projects & Achievements</a>
                    <a href="skills.html" class="text-mutedtext hover:text-lighttext transition-colors">Skills</a>
                    <a href="contact.html" class="text-mutedtext hover:text-lighttext transition-colors">Contact</a>
                </div>
                <!-- Theme Toggle -->
                <button id="theme-toggle" class="p-2 rounded-full text-mutedtext hover:text-lighttext focus:outline-none focus:ring-2 focus:ring-primary transition-colors">
                    <svg id="dark-mode-svg" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                    </svg>
                    <svg id="light-mode-svg" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h1M3 12H2m8.66-8.66l-.707-.707M16.34 16.34l.707.707M16.34 7.66l.707-.707M7.66 16.34l-.707.707M12 7a5 5 0 100 10 5 5 0 000-10z"></path>
                    </svg>
                </button>
                <!-- Mobile Menu Button -->
                <button id="mobile-menu-button" class="md:hidden p-2 rounded-md text-mutedtext hover:text-lighttext focus:outline-none focus:ring-2 focus:ring-primary transition-colors">
                    <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu (Hidden by default) -->
        <div id="mobile-menu" class="hidden md:hidden absolute top-16 left-0 w-full bg-darksurface shadow-lg py-2">
            <div class="flex flex-col space-y-2 px-4">
                <a href="about.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    About
                </a>
                <a href="achievements.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M17 16l4-4m-4 4l-4-4m4 4V8"></path></svg>
                    Projects & Achievements
                </a>
                <a href="skills.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4M17 17h4M16 3h4M3 16h4M17 3v4M3 3h.01M12 8v4l3 3m-3-3l-3 3"></path></svg>
                    Skills
                </a>
                <a href="contact.html" class="block py-2 px-3 text-lighttext hover:bg-primary/20 rounded-md transition-colors flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    Contact
                </a>
            </div>
        </div>
    </nav>

    <main class="pt-16 bg-darkbg">
        <section class="py-20 md:py-24 px-4">
            <div class="container mx-auto max-w-4xl">
                <h1 class="text-5xl font-extrabold text-primary mb-6 animate-fade-in-down">
                    <span class="inline-block animate-pulse mr-2">🤖</span> Sova — Autonomous AI Desktop Operating Assistant
                </h1>
                <p class="text-xl text-mutedtext mb-8 animate-fade-in-up delay-200">
                    Sova is an autonomous AI desktop assistant I engineered to act as an intelligent control layer over a computer system. It combines LLM reasoning with tool execution, persistent memory, emotional modeling, project architecture generation, codebase modification, real-time streaming, task scheduling, and proactive automation. Sova can manage files, run applications, modify software projects, spawn agents, and learn from past tasks, making it an AI-powered operating assistant rather than a traditional chatbot.
                </p>

                <!-- Narration Button -->
                <div class="mb-12 text-center md:text-left">
                    <p class="text-mutedtext mb-4">Click this button to listen to Sova's birth narrative:</p>
                    <button id="open-narration-modal" class="inline-block bg-primary hover:bg-secondary text-lighttext font-bold py-2 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-75 animate-fade-in-up delay-400">
                        <span class="mr-2">🎙️</span> Narrate
                    </button>
                </div>

                <a href="achievements.html#projects-content" class="inline-block bg-primary hover:bg-secondary text-lighttext font-bold py-2 px-4 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-opacity-75 mb-12">← Back to Projects & Achievements</a>

                <div class="space-y-12">
                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">🧠 Core Intelligence Layer</h3>
                        <p class="text-mutedtext mb-4">At the center of Sova is a custom AI orchestration engine (SovaCore) that:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>Manages conversation state</li>
                            <li>Routes tool calls</li>
                            <li>Handles LLM interaction</li>
                            <li>Executes multi-step reasoning workflows</li>
                            <li>Performs automatic retry, key rotation, and fault handling</li>
                        </ul>
                        <p class="text-mutedtext mt-4">Sova does not just answer questions — she decides actions, executes system operations, and manages tasks dynamically.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">1. Tool-Driven AI Architecture</h3>
                        <p class="text-mutedtext mb-4">Sova can call structured system tools instead of just generating text.</p>
                        <p class="text-mutedtext mb-4">She can:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>🖱 Move the mouse</li>
                            <li>⌨ Type</li>
                            <li>📂 Read and write files</li>
                            <li>🧠 Organize data</li>
                            <li>🖥 Interact with applications</li>
                            <li>🔊 Adjust hardware (volume, brightness)</li>
                            <li>💻 Run Python scripts</li>
                            <li>🖱 Control mouse and keyboard input</li>
                        </ul>
                        <p class="text-mutedtext mt-4">This turns AI reasoning into real-world system control.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">2. Autonomous Software Engineering (Sova Alpha)</h3>
                        <p class="text-mutedtext mb-4">Sova includes a specialized sub-system called Sova Alpha that:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>Designs full project architectures</li>
                            <li>Manages directories</li>
                            <li>Generates multi-file software structures</li>
                            <li>Handles environment setup</li>
                        </ul>
                        <p class="text-mutedtext mt-4">Instead of dumping code in chat, Sova delegates complex builds to an internal project architect engine.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">3. Live Code Modification System (Sova-Luxe)</h3>
                        <p class="text-mutedtext mb-4">Sova can read an entire project folder, understand the codebase, and modify it.</p>
                        <p class="text-mutedtext mb-4">She can:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>Fix bugs</li>
                            <li>Add new features</li>
                            <li>Refactor structures</li>
                            <li>Improve UI/UX</li>
                            <li>Update logic</li>
                        </ul>
                        <p class="text-mutedtext mt-4">All through AI-powered file analysis and rewriting.</p>
                        <p class="text-mutedtext mt-4">This is AI-assisted software maintenance, not just generation.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">4. Persistent Memory & Learning Engine</h3>
                        <p class="text-mutedtext mb-4">Sova remembers:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>User preferences</li>
                            <li>Past tasks</li>
                            <li>Conversation history</li>
                            <li>Failures and corrections</li>
                        </ul>
                        <p class="text-mutedtext mt-4">She includes a learning engine that:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>📘 Logs experiences</li>
                            <li>🧠 Reflects on failures</li>
                            <li>🔁 Attempts self-correction</li>
                            <li>📈 Improves future task handling</li>
                        </ul>
                        <p class="text-mutedtext mt-4">She gets smarter over time.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">5. Emotional Intelligence Module</h3>
                        <p class="text-mutedtext mb-4">Sova detects and tracks:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>User emotional state</li>
                            <li>Her own response tone</li>
                        </ul>
                        <p class="text-mutedtext mt-4">Each response includes an internal emotional tag (e.g., Empathetic, Analytical, Cheerful), allowing adaptive conversational behavior.</p>
                        <p class="text-mutedtext mt-4">This creates a more human-like interaction layer.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">6. Real-Time Streaming AI Responses</h3>
                        <p class="text-mutedtext mb-4">Sova streams responses in real-time using a high-speed streaming system, enabling:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>⚡ Low-latency conversation</li>
                            <li>🔄 Continuous output flow</li>
                            <li>🎧 Voice output integration</li>
                        </ul>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">7. Proactive Behavior Engine</h3>
                        <p class="text-mutedtext mb-4">Sova does not only react — she can act proactively.</p>
                        <p class="text-mutedtext mb-4">She can:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>📌 Monitor system conditions</li>
                            <li>📌 Apply rules</li>
                            <li>📌 Trigger automated actions</li>
                            <li>📌 Suggest optimizations</li>
                        </ul>
                        <p class="text-mutedtext mt-4">Example: detecting system slowness and offering to close heavy apps.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">8. Multi-Agent & Bot Management</h3>
                        <p class="text-mutedtext mb-4">Sova can:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>🤖 Spawn automation bots</li>
                            <li>📊 Monitor bot status</li>
                            <li>🛑 Terminate bots</li>
                            <li>📡 Receive live bot reports</li>
                        </ul>
                        <p class="text-mutedtext mt-4">She acts as a command center for other AI agents.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">9. Task Scheduling & Parallel Execution</h3>
                        <p class="text-mutedtext mb-4">With a global task scheduler, Sova can:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>Run multiple tasks simultaneously</li>
                            <li>Prioritize operations</li>
                            <li>Execute tools asynchronously</li>
                        </ul>
                        <p class="text-mutedtext mt-4">This gives her true agentic behavior, not single-threaded responses.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">10. Self-Correction Loop</h3>
                        <p class="text-mutedtext mb-4">If a task fails:</p>
                        <ul class="list-disc list-inside text-lighttext ml-4 space-y-2">
                            <li>Sova logs the failure</li>
                            <li>Reflects on what went wrong</li>
                            <li>Generates a corrected plan</li>
                            <li>Attempts again</li>
                        </ul>
                        <p class="text-mutedtext mt-4">That is autonomous recovery logic.</p>
                    </div>

                    <div class="bg-darksurface p-6 rounded-lg shadow-xl border border-darksurface hover:border-primary transition-all duration-300">
                        <h3 class="text-3xl font-bold text-lighttext mb-4">11. Full-Stack AI System</h3>
                        <div class="overflow-x-auto">
                            <table class="min-w-full bg-darkbg rounded-lg text-left text-lighttext">
                                <thead>
                                    <tr>
                                        <th class="py-3 px-4 border-b border-primary/50 text-primary font-semibold">Layer</th>
                                        <th class="py-3 px-4 border-b border-primary/50 text-primary font-semibold">Function</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">AI Brain</td>
                                        <td class="py-3 px-4">Gemini LLM</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Control Core</td>
                                        <td class="py-3 px-4">SovaCore</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Memory</td>
                                        <td class="py-3 px-4">Persistent + retrieval</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Learning</td>
                                        <td class="py-3 px-4">Experience logging + reflection</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Execution</td>
                                        <td class="py-3 px-4">ToolManager + System Tools</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Automation</td>
                                        <td class="py-3 px-4">AutomationEngine</td>
                                    </tr>
                                    <tr class="border-b border-darksurface">
                                        <td class="py-3 px-4">Scheduling</td>
